rules_version = '2';

// Reglas de Firebase Storage para la app M3
service firebase.storage {
  match /b/{bucket}/o {
    // Imágenes del chat - permitir lectura y escritura a usuarios autenticados
    match /chat-images/{imageId} {
      // Permitir lectura a todos (para mostrar imágenes en el chat)
      allow read: if true;
      // Solo usuarios autenticados pueden subir imágenes
      allow write: if request.auth != null;
    }
    
    // Regla general - denegar todo lo demás por seguridad
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
